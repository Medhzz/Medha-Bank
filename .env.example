# ─── Bank Identity ───────────────────────────────────────────────
VITE_BANK_ID=med404
VITE_BANK_NAME=Medha Bank
VITE_IFSC_CODE=MNOP

# ─── Private Firebase (auth + customer data) ─────────────────────
VITE_PRIVATE_API_KEY=your_private_api_key
VITE_PRIVATE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_PRIVATE_PROJECT_ID=your-project-id
VITE_PRIVATE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_PRIVATE_MESSAGING_SENDER_ID=your_sender_id
VITE_PRIVATE_APP_ID=your_app_id

# ─── Shared Hub Firebase (inter-bank transfers) ───────────────────
VITE_HUB_API_KEY=your_hub_api_key
VITE_HUB_AUTH_DOMAIN=your-hub-project.firebaseapp.com
VITE_HUB_PROJECT_ID=your-hub-project-id
VITE_HUB_STORAGE_BUCKET=your-hub-project.firebasestorage.app
VITE_HUB_MESSAGING_SENDER_ID=your_hub_sender_id
VITE_HUB_APP_ID=your_hub_app_id

# ─── Hub Service Account (auto sign-in to hub) ───────────────────
VITE_HUB_BANK_EMAIL=your_hub_service_email@gmail.com
VITE_HUB_BANK_PASSWORD=your_hub_service_password

# ─── EmailJS Notifications (optional) ────────────────────────────
# Leave blank to skip email notifications gracefully
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
